<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- API 27+ override: opt into translucent system bars so the full-screen
         camera preview extends behind the status bar and navigation bar.
         android:windowLayoutInDisplayCutoutMode is not applied here because
         it requires API 28; that attribute is added in values-v28/styles.xml. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>
</resources>
